{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/governance-audit/audit-session-start.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/governance-audit/audit-session-end.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/governance-audit/audit-prompt.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "env": {
    "GOVERNANCE_LEVEL": "standard",
    "BLOCK_ON_THREAT": "false"
  }
}
